{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build WapProj",
      "type": "shell",
      "command": "dotnet",
      "args": ["msbuild",
        "CodeEditor-WinUI-TestApp/CodeWriter-WinUI-TestApp (Package)/CodeEditor-WinUI-TestApp (Package).wapproj",
        "/restore",
        "/t:Publish",
        "/p:WapProjPath=C:\\Program Files\\Microsoft Visual Studio\\18\\Insiders\\MSBuild\\Microsoft\\DesktopBridge\\",
        "/p:Configuration=Release",
        "/p:Platform=x64",
        "/p:AppxPackageSigningEnabled=false"
      ],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": "$msCompile",
      "presentation": { "reveal": "always" }
    },
    {
      "label": "Run Test App",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "CodeEditor-WinUI-TestApp/CodeWriter-WinUI-TestApp/CodeEditor-WinUI-TestApp.csproj",
        "--configuration",
        "Debug",
        "--framework",
        "net10.0-windows10.0.26100.0"
      ],
      "group": "none",
      "dependsOn": [],
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    }
  ]
}
